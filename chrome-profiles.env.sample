CHROME_PROFILE_BASE_NAME=Work
CHROME_PROFILE_RANGE=[4,7]
CHROME_PROFILE_ROOT=chrome-profiles
CHROME_START_URLS=https://contactout.com/;https://outlook.com/
## Optional: append each launch to a text log file.
# CHROME_LAUNCH_LOG_FILE=chrome-profile-launcher.log
## Optional: one authenticated proxy URL per line.
# CHROME_PROXY_FILE=chrome-proxy-list.txt
## Optional: zero-based proxy index from CHROME_PROXY_FILE to reuse for every profile in CHROME_PROFILE_RANGE.
# CURRENT_PROXY=0
## Optional: mapping when CURRENT_PROXY is not set.
## range = first selected profile uses the first proxy from the chosen slice.
## profile = Work41 uses proxy line 41 by default.
## cycle = wrap around when the profile range is larger than the proxy slice.
## random = choose proxies randomly from the file for each launched profile.
# CHROME_PROXY_STRATEGY=range
## Optional: zero-based starting line in CHROME_PROXY_FILE for range/cycle mapping.
# CHROME_PROXY_START_INDEX=0
## Optional: make random proxy assignment repeatable across runs.
# CHROME_PROXY_RANDOM_SEED=123
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
